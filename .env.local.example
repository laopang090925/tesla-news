# NewsAPI - https://newsapi.org/ 免费注册获取
NEWS_API_KEY=your_newsapi_key_here

# Resend - https://resend.com/ 免费注册获取
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# 收件邮箱
TO_EMAIL=zhangdaqi92@gmail.com

# 发件邮箱域名（需在 Resend 验证域名，或用 onboarding@resend.dev 测试）
FROM_EMAIL=Tesla日报 <digest@yourdomain.com>

# Vercel Cron 安全密钥（随机字符串，在 Vercel 环境变量中设置同一个值）
CRON_SECRET=your_random_secret_here

# Vercel Blob Token（在 Vercel 项目中添加 Blob 存储后自动生成）
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx
